generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums para Gestão de SaaS
enum Plan {
  STARTER
  PRO
  BUSINESS
}

enum Role {
  ADMIN
  PROFESSIONAL
  USER
}

enum AppointmentStatus {
  SCHEDULED
  CANCELED
  COMPLETED
}

model User {
  id                      String         @id @default(cuid())
  email                   String         @unique
  name                    String
  password                String
  username                String         @unique
  avatarUrl               String?
  bio                     String?
  phone                   String?
  
  // Configurações de SaaS
  role                    Role           @default(USER)
  plan                    Plan           @default(STARTER)
  maxMembers              Int            @default(3)
  
  // Hierarquia de Equipe
  ownerId                 String?   
  owner                   User?          @relation("TeamHierarchy", fields: [ownerId], references: [id])
  teamMembers             User[]         @relation("TeamHierarchy")

  // Configurações de Agendamento
  timezone                String         @default("America/Sao_Paulo")
  bufferMinutes           Int            @default(0)
  minBookingNoticeMinutes Int            @default(0)
  maxBookingDays          Int            @default(30)
  
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt

  // 👇 RELAÇÕES DE SERVIÇOS ATUALIZADAS
  ownedServices           Service[]      @relation("UserOwnedServices")     // Serviços CRIADOS pela conta (Catálogo Mestre)
  services                Service[]      @relation("ProfessionalServices")  // Serviços EXECUTADOS por este profissional

  // Outras Relações
  clients                 Client[]
  businessHours           BusinessHour[]
  blockedDates            BlockedDate[]
  blockedSlots            BlockedSlot[]
  
  // Agendamentos realizados POR este usuário (como profissional)
  appointments            Appointment[]  @relation("ProfessionalAppointments")
  
  // Agendamentos pertencentes à CONTA deste usuário (como dono)
  ownedAppointments       Appointment[]  @relation("AccountAppointments")
}

model Service {
  id           String        @id @default(cuid())
  userId       String        // ID do dono da conta (Admin) que criou o serviço
  name         String
  icon         String        @default("scissors")
  duration     Int
  priceCents   Int
  imageUrl     String?
  
  // 👇 RELAÇÕES DE USUÁRIOS ATUALIZADAS
  user         User          @relation("UserOwnedServices", fields: [userId], references: [id]) 
  professionals User[]       @relation("ProfessionalServices")                                 
  
  appointments Appointment[]
}

model Appointment {
  id                        String             @id @default(uuid())
  date                      DateTime
  status                    AppointmentStatus
  notes                     String?
  
  // Profissional que executará o serviço
  professionalId            String
  professional              User               @relation("ProfessionalAppointments", fields: [professionalId], references: [id])
  
  // Dono da conta (para relatórios e faturamento)
  userId                    String
  user                      User               @relation("AccountAppointments", fields: [userId], references: [id])

  serviceId                 String
  service                   Service            @relation(fields: [serviceId], references: [id])
  
  clientId                  String?
  client                    Client?            @relation(fields: [clientId], references: [id])

  publicCancelToken         String?            @unique
  publicCancelTokenExpiresAt  DateTime?
  dayReminderSentAt         DateTime?
  dayReminderProcessingAt   DateTime?
  hourReminderSentAt        DateTime?
  hourReminderProcessingAt  DateTime?
  createdAt                 DateTime           @default(now())

  paymentStatus             String             @default("NOT_REQUIRED") // NOT_REQUIRED, PENDING, PAID, REFUNDED
  transactionId             String?            @unique                  // ID gerado pelo Mercado Pago
  depositCents              Int?                                        // Valor cobrado antecipadamente
  pixPayload                String?            @db.Text                 // Código PIX Copia e Cola
}

model BlockedDate {
  id        String   @id @default(uuid())
  userId    String
  date      DateTime
  reason    String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

model BlockedSlot {
  id        String   @id @default(uuid())
  userId    String
  start     DateTime
  end       DateTime
  reason    String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([start])
  @@index([end])
}

model BusinessHour {
  id        String   @id @default(uuid())
  userId    String
  weekday   Int
  start     String
  end       String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, weekday, start, end])
}

model Client {
  id        String   @id @default(uuid())
  userId    String
  name      String
  phone     String?
  email     String?
  notes     String?
  createdAt DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id])
  appointments Appointment[]

  @@index([userId])
  @@unique([userId, phone])
}