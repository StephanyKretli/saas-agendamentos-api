generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(USER)
  username String    @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  services       Service[]
  appointments   Appointment[]
  clients        Client[]
  businessHours  BusinessHour[]
  blockedDates   BlockedDate[]
  blockedSlots   BlockedSlot[]
}

model Service {
  id         String   @id @default(cuid())
  userId     String
  name       String
  duration   Int
  priceCents Int

  user User @relation(fields: [userId], references: [id])

  appointments Appointment[]
}

model Appointment {
  id                        String            @id @default(uuid())
  userId                    String
  serviceId                 String
  clientId                  String?
  date                      DateTime
  status                    AppointmentStatus
  notes                     String?
  publicCancelToken         String?           @unique
  publicCancelTokenExpiresAt DateTime?
  createdAt                 DateTime          @default(now())
  reminderSentAt            DateTime?

  user    User    @relation(fields: [userId], references: [id])
  service Service @relation(fields: [serviceId], references: [id])
  client  Client? @relation(fields: [clientId], references: [id])
}

model BlockedDate {
  id        String   @id @default(uuid())
  userId    String
  date      DateTime
  reason    String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

model BlockedSlot {
  id        String   @id @default(uuid())
  userId    String
  start     DateTime
  end       DateTime
  reason    String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([start])
  @@index([end])
}

model BusinessHour {
  id        String   @id @default(uuid())
  userId    String
  weekday   Int
  start     String
  end       String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, weekday, start, end])
}

model Client {
  id        String   @id @default(uuid())
  userId    String
  name      String
  phone     String?
  email     String?
  notes     String?
  createdAt DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id])
  appointments Appointment[]

  @@index([userId])
  @@unique([userId, phone])
}

enum AppointmentStatus {
  SCHEDULED
  CANCELED
  COMPLETED
}

enum Role {
  ADMIN
  USER
}
