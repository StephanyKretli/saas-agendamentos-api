generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  blockedDates  BlockedDate[]
  businessHours BusinessHour[]
  blockedSlots  BlockedSlot[]
  appointments  Appointment[]
  services      Service[]
  clients       Client[]
}

model Service {
  id         String   @id @default(uuid())
  userId     String
  name       String
  duration   Int
  priceCents Int
  createdAt  DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id])
  appointments Appointment[]

  @@index([userId])
}

model Appointment {
  id        String            @id @default(uuid())
  userId    String
  serviceId String
  clientId  String?
  date      DateTime
  status    AppointmentStatus
  notes     String?
  createdAt DateTime          @default(now())

  user    User    @relation(fields: [userId], references: [id])
  service Service @relation(fields: [serviceId], references: [id])
  client  Client? @relation(fields: [clientId], references: [id])
}

model BlockedDate {
  id        String   @id @default(uuid())
  userId    String
  date      DateTime
  reason    String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

model BlockedSlot {
  id        String   @id @default(uuid())
  userId    String
  start     DateTime
  end       DateTime
  reason    String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([start])
  @@index([end])
}

model BusinessHour {
  id        String   @id @default(uuid())
  userId    String
  weekday   Int
  start     String
  end       String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([weekday])
}

model Client {
  id        String   @id @default(uuid())
  userId    String
  name      String
  phone     String?
  email     String?
  notes     String?
  createdAt DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id])
  appointments Appointment[]

  @@index([userId])
}

enum AppointmentStatus {
  SCHEDULED
  CANCELED
  COMPLETED
}

enum Role {
  ADMIN
  USER
}
